          "affectedCharacters": ["salome", "albert", "krosov", "irina"],
          "severity": "critical",
          "anchorLevel": "fixed",
          "frames": [
            {
              "id": "pf-krosov-arrives-001",
              "eventId": "krosov-arrives",
              "speaker": "krosov",
              "addressee": "albert",
              "content": {
                "dialogue": "新年快乐，霍利曼先生。",
                "narration": "他推开门，纳甘的枪口在礼节性的语调里径直对准了对方额头。",
                "emotion": "calm"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-002",
              "eventId": "krosov-arrives",
              "speaker": "krosov",
              "addressee": "salome",
              "content": {
                "dialogue": "新年快乐，莎乐美小姐。",
                "emotion": "polite"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-003",
              "eventId": "krosov-arrives",
              "speaker": "albert",
              "addressee": "krosov",
              "content": {
                "dialogue": "去年差不多这时候，贵方确实缔造了一项震惊世界的创举。苏维埃社会主义共和国联盟——所以克罗索夫先生如今已是布尔什维克的爪牙了？",
                "narration": "即便被枪口指着，阿尔伯特依旧扬起下颌。",
                "emotion": "defiant"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-004",
              "eventId": "krosov-arrives",
              "speaker": "krosov",
              "addressee": "albert",
              "content": {
                "dialogue": "沉湎于旧事，在这里并无意义。在下眼下不过是国家政治保卫总局的一名处长，仅此而已。",
                "narration": "克罗索夫抬高声音，平静地截断了对方。",
                "emotion": "calm"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-005",
              "eventId": "krosov-arrives",
              "speaker": null,
              "content": {
                "dialogue": "三者之间，一条无形的力学链条：阿尔伯特的匕首抵着莎乐美的颈间；莎乐美的身影恰好遮住了狙击手的射击角度；克罗索夫的枪口锁定着阿尔伯特。任何一方的动作都会破坏平衡，而平衡一旦破坏，结局只有一种。",
                "style": "italic"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-006",
              "eventId": "krosov-arrives",
              "speaker": "albert",
              "addressee": "krosov",
              "content": {
                "dialogue": "局面的确有些复杂，不是吗。这位女士在我的控制之下，我的性命则悬于您的枪口，而以这样的距离，双方都不会失手。况且您和我一样，需要的是活着的莎乐美小姐。",
                "emotion": "analytical"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-007",
              "eventId": "krosov-arrives",
              "speaker": "krosov",
              "addressee": "albert",
              "content": {
                "dialogue": "我们和你们不一样。莎乐美同志是苏联公民。无论是曾经的沙俄还是现在的苏联，我们都会保护她的安全——",
                "narration": "话说到一半，他瞥见了莎乐美的表情。正在朝他微笑。不是求援，也不是感激。只是微笑。那个笑容让他产生了一种不太好的预感。",
                "emotion": "earnest"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            },
            {
              "id": "pf-krosov-arrives-008",
              "eventId": "krosov-arrives",
              "speaker": "albert",
              "addressee": "krosov",
              "content": {
                "dialogue": "理由冠冕堂皇，归根结底，不过是和我们觊觎着同一样东西。这个女人在我手中，我没有打算将她交给你们。只要做出任何过激的动作，我会确保——我们得不到的，你们也别想得到。",
                "narration": "阿尔伯特的目光变得锋利。",
                "emotion": "threatening"
              },
              "ratified": ["krosov", "albert", "salome"],
              "eavesdroppers": ["goering"]
            }
