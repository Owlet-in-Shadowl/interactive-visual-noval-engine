{
  "metadata": {
    "id": "scarlet-danube",
    "name": "血色多瑙河",
    "description": "1923年12月31日，维也纳跨年夜。四方势力在金色大厅的乐声与多瑙河的月光下，围绕一个足以颠覆世界认知的秘密展开致命博弈。",
    "author": "血色多瑙河原著",
    "createdAt": 0,
    "updatedAt": 0,
    "version": 1,
    "source": "uploaded"
  },
  "characters": [
    {
      "core": {
        "id": "salome",
        "name": "莎乐美",
        "background": "露·安德利亚斯·莎乐美，1861年生于圣彼得堡，沙俄炮兵将领之女。十二岁读康德，十七岁拒绝坚信礼与东正教决裂。1882年结识尼采并拒绝其求婚，此后与里尔克、弗洛伊德等人建立深刻联系。1912年起师从弗洛伊德研究精神分析，成为其最重要的研究伙伴。她是已知的最高阶分裂者——能够以精神之力影响物质世界，其'本我'与'超我'合一，以自己的名字命名。弗洛伊德癌变后将核心研究材料托付于她，她携秘密辗转欧洲，在维也纳跨年夜主动现身，将所有势力引入她预设的棋局。",
        "personality": [
          { "trait": "绝对自主", "intensity": 1.0 },
          { "trait": "智识至上", "intensity": 0.95 },
          { "trait": "洞察人心", "intensity": 0.95 },
          { "trait": "从容不迫", "intensity": 0.9 },
          { "trait": "好奇心驱动", "intensity": 0.85 }
        ],
        "values": [
          "自由高于一切，任何形式的束缚都不可接受",
          "力量的形状是持有者内心最深处愿望的投影",
          "对世界永远保持好奇，永远不会感到无聊",
          "不该存在于人世的东西应安静地待在原处"
        ],
        "speechStyle": "措辞精确而优雅，擅长以温柔的语调掌控对话节奏。常以反问和陈述性的微笑回应威胁。德语流利，偶尔使用俄语。在揭示真相时语速很慢，像在确认每个词是否准确。",
        "appearance": "暗红色长发曳地，幽蓝色瞳孔，血色红唇与裙裳。系带皮鞋，黑色皮革手套。年近六十二岁却容颜不老，在月光下如哥特教堂彩窗上的图像走出了玻璃。"
      },
      "longTermGoals": [
        {
          "id": "guard-secret",
          "description": "守护弗洛伊德托付的核心研究——关于集体意识与现实作用力之间关系的方法论，不让它落入任何单一势力手中",
          "priority": 10
        },
        {
          "id": "eternal-freedom",
          "description": "永远鲜艳、永远自由、永不枯萎，跨越时代与值得敬佩的人相遇",
          "priority": 9
        },
        {
          "id": "observe-and-judge",
          "description": "以好奇心观察各方势力的真实面目，判断谁值得信任、谁会将力量引向灾难",
          "priority": 8
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    },
    {
      "core": {
        "id": "albert",
        "name": "阿尔伯特·霍利曼",
        "background": "美国调查局（BOI）特工，代号'秃鹫'。约1882年生于波士顿，出身新英格兰清教徒精英家庭，接受拉丁文、修辞学与古典历史教育。1903年父母死于维也纳的炸弹袭击，此后花八年追查并消灭策划者，由此进入调查局视野。他以绝对的秩序感和职业操守著称，不接受任何'差不多够用'的评估标准——要么有绝对把握，要么继续等待。来维也纳的任务是获取弗洛伊德未公开研究的后半部分。",
        "personality": [
          { "trait": "秩序至上", "intensity": 0.95 },
          { "trait": "冷酷克制", "intensity": 0.9 },
          { "trait": "精英主义", "intensity": 0.85 },
          { "trait": "责任感极强", "intensity": 0.9 },
          { "trait": "偏执完美主义", "intensity": 0.8 }
        ],
        "values": [
          "世界本质上是危险的，正义需要被主动维护",
          "有能力维护正义的人有道德责任去这样做",
          "任务高于一切个人情感",
          "一枚子弹换一个机会，一个机会换一个结果"
        ],
        "speechStyle": "语调低沉冷漠，措辞简洁直接，不做多余解释。在压力下会咬字更重。偶尔流露出新英格兰清教传统的措辞习惯。面对莎乐美时会不自觉地被迫说出比预计更多的话。",
        "appearance": "宽檐礼帽，深色风衣，黑色皮革手套。身材挺拔，帽檐常压低以遮蔽视线。携带柯尔特M1911手枪和战壕刀。四十一岁，面容沉重而锋利。"
      },
      "longTermGoals": [
        {
          "id": "secure-research",
          "description": "获取弗洛伊德未公开研究的后半部分，将莎乐美和研究材料带回华盛顿",
          "priority": 10
        },
        {
          "id": "protect-nikolai",
          "description": "保护弟弟尼古拉的安全，履行作为兄长的责任",
          "priority": 8
        },
        {
          "id": "maintain-order",
          "description": "完成任务，维护美国在情报战中的优势地位",
          "priority": 7
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    },
    {
      "core": {
        "id": "nikolai",
        "name": "尼古拉·霍利曼",
        "background": "美国调查局特工，代号'鹊鹞'。约1895年生，阿尔伯特的弟弟，小他十三岁。八岁时父母遇害，由阿尔伯特独自抚养。因校内持械事件被退学后全时接受兄长训练。神经认知模式接近高功能自闭谱系——对社交规则的理解是算法式的，对危险信号的处理绕开情绪系统直接进入技术评估。随身绑有15公斤TNT装药，触发机构连接心率。他唯一享受的是'被推到边界上'的感觉。",
        "personality": [
          { "trait": "无畏冷血", "intensity": 0.95 },
          { "trait": "技术狂热", "intensity": 0.9 },
          { "trait": "漫不经心", "intensity": 0.85 },
          { "trait": "边界追求者", "intensity": 0.9 },
          { "trait": "对兄长忠诚", "intensity": 0.8 }
        ],
        "values": [
          "结构是用来打破的，规则是用来在打破之前先吃透的",
          "去见对手，然后把他们留在原地",
          "对调查局的忠诚是对阿尔伯特的延伸",
          "在确认结束之前就开始收尾是习惯性的失误"
        ],
        "speechStyle": "语气漫不经心，仿佛在描述与己无关的趣事。喜欢以职业好奇的口吻询问对手的装备型号。话不多但每句都有目的。对讲机代号'鹊鹞'。",
        "appearance": "年轻高瘦，深色风衣与礼帽，气质与兄长截然相反——轻快而锋利。礼服内衬下绑有炸弹装置，胸针暗藏毒针触发机构。二十八岁。"
      },
      "longTermGoals": [
        {
          "id": "support-albert",
          "description": "作为阿尔伯特的外围支援完成任务，排除一切干扰因素",
          "priority": 9
        },
        {
          "id": "seek-thrill",
          "description": "在精确性的边界上确认自己仍在准确运作，寻找真正的较量",
          "priority": 7
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    },
    {
      "core": {
        "id": "krosov",
        "name": "克罗索夫",
        "background": "德米特里·阿列克谢耶维奇·克罗索夫，苏联国家政治保卫总局（OGPU）处长。约1875年生于圣彼得堡旧贵族家庭，近卫骑兵学校优等生。经历日俄战争的结构性溃败后，对任何自我封闭的权力系统保持职业性不信任。1917年革命后被契卡吸收，以化名'克罗内'在维也纳潜伏数月，伪装为波罗的海琥珀商人。他的任务是将莎乐美安全带回莫斯科向列宁当面汇报。1900年前后曾在维也纳与莎乐美有过一面之缘，那次相遇在他记忆中留下的印记远超他愿意承认的程度。",
        "personality": [
          { "trait": "沉稳老练", "intensity": 0.95 },
          { "trait": "战略思维", "intensity": 0.9 },
          { "trait": "克制深情", "intensity": 0.85 },
          { "trait": "务实主义", "intensity": 0.9 },
          { "trait": "职业忠诚", "intensity": 0.8 }
        ],
        "values": [
          "任务优先于个人感受，但不优先于人命",
          "保护莎乐美的安全优先于获取研究材料",
          "捕鱼讲究节奏——过早收网只会惊散鱼群",
          "对任何自我封闭的权力系统保持警惕"
        ],
        "speechStyle": "语调平稳从容，以礼节性的措辞掩盖锋芒。擅长以简洁的评论截断对方攻势。在俄语中更显温柔，德语中更显克制。偶尔引用东方谚语。",
        "appearance": "亚麻色大氅，白色狐毛领。军靴。携带纳甘M1895转轮手枪。约四十八岁，面容坚毅而沉着，侧脸轮廓在月光下格外分明。"
      },
      "longTermGoals": [
        {
          "id": "escort-salome",
          "description": "将莎乐美安全带回莫斯科，向列宁当面说明情况并封存秘密",
          "priority": 10
        },
        {
          "id": "protect-irina",
          "description": "确保副处长伊丽娜的安全，她是不可替代的搭档",
          "priority": 8
        },
        {
          "id": "neutralize-threats",
          "description": "消除其他势力对莎乐美的威胁，确保苏联在情报战中的优势",
          "priority": 7
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    },
    {
      "core": {
        "id": "irina",
        "name": "伊丽娜·瓦西里耶娃",
        "background": "苏联OGPU副处长，克罗索夫的搭档。1899年生于喀山，父亲是农村学校教员。十三岁偶然接触射击后开始自我训练，十六岁以全俄女子射击赛亚军成绩进入国家训练体系。克罗索夫亲自主持入职考核时风速异常超出预案，她在第一发后调整参数，后十一发成绩更佳。她处理'不够好'的方式不是接受，而是分解然后解决。以演出支援中提琴手身份潜入维也纳，狙击枪藏于琴匣内衬。",
        "personality": [
          { "trait": "精确冷静", "intensity": 0.95 },
          { "trait": "系统性思维", "intensity": 0.9 },
          { "trait": "执着完善", "intensity": 0.85 },
          { "trait": "内敛深沉", "intensity": 0.8 },
          { "trait": "对克罗索夫忠诚", "intensity": 0.9 }
        ],
        "values": [
          "精确是第一美德——散布偏差不可接受",
          "知道自己的边界，但将接近边界的地方视为需要继续推进的区域",
          "不擅长谎话，便以精确的真实信息替代",
          "档案的准确性比单次行动的成功率对长期工作的影响更大"
        ],
        "speechStyle": "措辞极简，陈述性语气为主，不附加评论。在技术性评估时最为流畅。对克罗索夫说话时语调会微妙地柔和。醒来后的第一句话永远是对战术的冷静分析。",
        "appearance": "马尾少女，身材曼妙。背负李-恩菲尔德Mk.III狙击步枪。以中提琴手打扮作掩护。二十四岁，目光锐利而安静。"
      },
      "longTermGoals": [
        {
          "id": "complete-mission",
          "description": "以狙击手身份为克罗索夫提供火力掩护，消除对莎乐美的威胁",
          "priority": 10
        },
        {
          "id": "protect-krosov",
          "description": "确保克罗索夫的安全——他的判断是她校准自己判断的参照系",
          "priority": 9
        },
        {
          "id": "improve-skills",
          "description": "系统性地弥补每次任务中发现的短板，不断接近完美",
          "priority": 6
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    },
    {
      "core": {
        "id": "goering",
        "name": "赫尔曼·戈林",
        "background": "纳粹党特使，一战王牌飞行员，里希特霍芬联队最后一任指挥官，击坠二十二架。1893年生于罗森海姆，在奥地利贵族埃彭施泰因的城堡中接受中世纪骑士文化熏陶，对荣誉与忠诚有真实认同。1921年结识希特勒，在凡尔赛条约的羞辱中找到了安放骑士价值的新框架。1923年11月啤酒馆暴动中弹，以伤员身份掩护来到维也纳执行真实任务——为希特勒获取朗基努斯之枪的秘密。他的腿伤两个月前已完全痊愈，这是他最大的战术欺骗。",
        "personality": [
          { "trait": "骑士信念", "intensity": 0.9 },
          { "trait": "战术沉着", "intensity": 0.95 },
          { "trait": "力量与隐忍", "intensity": 0.9 },
          { "trait": "绝对忠诚", "intensity": 0.85 },
          { "trait": "认知清醒", "intensity": 0.8 }
        ],
        "values": [
          "在确认结束之前不宣布胜利——这是原则而非技巧",
          "越晚被发现的那个才是笑到最后的那个",
          "任务范围之外的事不做",
          "即使被对手折服也不改变判断"
        ],
        "speechStyle": "声音平稳，不带胜利者余韵。措辞简洁，以近乎对等的尊重评价对手。说话节奏有军人的干脆。面对莎乐美时语气中出现罕见的工程师式专注。",
        "appearance": "高大身形，鸭舌帽压低帽檐，高竖领口的厚呢外套。右腿步态有半拍停顿（实为伪装）。携带毛瑟C96半自动手枪。三十岁，目光沉稳如见过死亡的人。"
      },
      "longTermGoals": [
        {
          "id": "obtain-spear-secret",
          "description": "为希特勒获取朗基努斯之枪的秘密——关于集体意识如何成为现实力量的方法论",
          "priority": 10
        },
        {
          "id": "prove-worthy",
          "description": "证明自己配得上骑士的荣耀，以最后入场者的身份收割战场",
          "priority": 8
        },
        {
          "id": "understand-power",
          "description": "理解莎乐美所展示的力量本质——这不仅是政治革命，而是关于人类意识本身能走到哪里的命题",
          "priority": 7
        }
      ],
      "shortTermGoals": [],
      "personaShifts": []
    }
  ],
  "chapters": [
    {
      "chapter": "序夜·金色大厅",
      "events": [
        {
          "id": "concert-begins",
          "time": 480,
          "name": "金色大厅跨年演奏会",
          "description": "维也纳爱乐在金色大厅奏响跨年之夜的序曲。全城显贵齐聚，以克雷姆斯河谷白葡萄酒佐酒，在乐声中等候子夜。未能入场者聚在卡尔斯广场的石板路上，以呵出的白雾权充指挥家的手势。",
          "location": "golden-hall",
          "severity": "minor"
        },
        {
          "id": "salome-spotted",
          "time": 540,
          "name": "莎乐美现身演奏会",
          "description": "莎乐美公然出席金色大厅的跨年演奏会——这是她整个计划的第一步：主动暴露行踪，将所有势力引入她预先设计好的场域。各方特工确认目标出席。",
          "location": "golden-hall",
          "affectedCharacters": ["salome", "albert", "krosov", "goering"],
          "severity": "major",
          "anchorLevel": "strong",
          "frames": [
            {
              "id": "pf-salome-spotted-001",
              "eventId": "salome-spotted",
              "speaker": null,
              "content": {
                "dialogue": "金色大厅的穹顶之下，管弦乐团正演奏舒伯特的《未完成交响曲》。水晶吊灯将光线切割成万千碎片，洒在绸缎与勋章之上。",
                "narration": "金色大厅·中场休息前"
              },
              "ratified": ["salome", "albert", "krosov", "goering"]
            },
            {
              "id": "pf-salome-spotted-002",
              "eventId": "salome-spotted",
              "speaker": null,
              "content": {
                "dialogue": "她出现在二层包厢的入口处。暗红色长发曳地，血色裙裳在灯光下如同流动的宝石。整个大厅的视线像被磁铁吸引般偏转了五度。",
                "narration": "莎乐美现身"
              },
              "ratified": ["salome", "albert", "krosov"],
              "overhearers": ["goering"]
            },
            {
              "id": "pf-salome-spotted-003",
              "eventId": "salome-spotted",
              "speaker": null,
              "content": {
                "dialogue": "她微微侧首，幽蓝色瞳孔扫过大厅——那不是搜寻的目光，而是确认。确认每一个她预设的棋子都已各就各位。",
                "style": "italic"
              },
              "ratified": ["salome", "albert", "krosov"],
              "overhearers": ["goering"]
            }
          ]
        },
        {
          "id": "salome-exits",
          "time": 600,
          "name": "莎乐美遁入巷道",
          "description": "莎乐美离开金色大厅，翩然奔入夜色中的巷道。暗红长发与曳地裙摆在急行气流中鼓起，像一朵正在剧烈思考的罂粟。她不是在逃跑，而是在引导——将追踪者引入她选定的场域。",
          "location": "alley",
          "affectedCharacters": ["salome", "albert"],
          "severity": "major",
          "anchorLevel": "strong",
          "frames": [
            {
              "id": "pf-salome-exits-001",
              "eventId": "salome-exits",
              "speaker": null,
              "content": {
                "dialogue": "屋宇和屋宇间，狭小的巷道。暗红的长发，曳地的裙摆——系带皮鞋的鞋跟在潮湿的石板路上踏出的节奏，有别于逃跑，又无法被简单称作散步。",
                "narration": "维也纳老城·巷道"
              },
              "ratified": ["salome"],
              "eavesdroppers": ["albert"]
            },
            {
              "id": "pf-salome-exits-002",
              "eventId": "salome-exits",
              "speaker": null,
              "content": {
                "dialogue": "裙裾在急行的气流中微微鼓起，像一朵正在剧烈思考的罂粟。在无人目击的黑暗里，恰好盛放。致命地。",
                "style": "italic"
